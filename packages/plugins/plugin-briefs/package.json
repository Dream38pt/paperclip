{
  "name": "@paperclipai/plugin-briefs",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Briefing cards plugin for deterministic Paperclip work summaries.",
  "files": [
    "dist",
    "migrations",
    "README.md"
  ],
  "scripts": {
    "postinstall": "node ../../../scripts/link-plugin-dev-sdk.mjs",
    "prebuild": "pnpm --filter @paperclipai/plugin-sdk ensure-build-deps",
    "build": "tsc",
    "test": "vitest run --config ./vitest.config.ts",
    "typecheck": "pnpm --filter @paperclipai/plugin-sdk ensure-build-deps && tsc --noEmit"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js"
  },
  "keywords": [
    "paperclip",
    "plugin",
    "briefs",
    "briefing"
  ],
  "author": "Paperclip",
  "license": "MIT",
  "devDependencies": {
    "@paperclipai/plugin-sdk": "workspace:*",
    "@types/node": "^24.6.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
